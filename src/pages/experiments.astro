---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ShaderToy from '../components/experiments/ShaderToy';
import PhysicsWorld from '../components/experiments/PhysicsWorld';
---

<BaseLayout title="Experiments" description="Web experiments and widgets." path="/experiments" noindex={true}>
  <Header />
  <h1 class="font-heading font-bold text-xl text-foreground mb-2">Experiments</h1>
  <p class="text-muted-foreground text-sm mb-4">
    You found it. Playful things, web experiments, and widgets that don't belong anywhere else.
  </p>
  <p class="text-muted text-xs mb-10">
    This page is unlisted. You're here because you clicked enough times.
  </p>

  <div class="grid grid-cols-1 gap-6 mb-10">
    <div class="border border-border rounded-xl p-4 bg-surface/50">
      <ShaderToy client:visible />
    </div>
    <div class="border border-border rounded-xl p-4 bg-surface/50">
      <PhysicsWorld client:visible />
    </div>
  </div>

  <Footer />
</BaseLayout>
