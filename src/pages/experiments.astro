---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Experiments" description="Web experiments and widgets." path="/experiments" noindex={true}>
  <Header />
  <h1 class="font-heading font-bold text-xl text-foreground mb-2">Experiments</h1>
  <p class="text-muted-foreground text-sm mb-4">
    You found it. Playful things, web experiments, and widgets that don't belong anywhere else.
  </p>
  <p class="text-muted text-xs mb-10">
    This page is unlisted. You're here because you clicked enough times.
  </p>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
    <div class="border border-border rounded-lg p-6 flex items-center justify-center min-h-[120px]">
      <span class="text-muted text-sm">Widget 1 — coming soon</span>
    </div>
    <div class="border border-border rounded-lg p-6 flex items-center justify-center min-h-[120px]">
      <span class="text-muted text-sm">Widget 2 — coming soon</span>
    </div>
  </div>

  <Footer />
</BaseLayout>
