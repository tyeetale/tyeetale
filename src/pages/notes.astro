---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes')).sort((a, b) => 
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Notes" description="Thoughts on building, AI, and systems thinking." path="/notes">
  <Header />
  <h1 class="font-heading font-bold text-xl text-foreground mb-2">Notes</h1>
  <p class="text-muted-foreground text-sm mb-10">
    Thoughts on building, AI, and systems thinking.
  </p>

  <div class="flex flex-col gap-6 mb-12">
    {notes.map((note) => (
      <a href={`/notes/${note.id.replace('.mdx', '')}`} class="group block">
        <span class="text-muted text-xs">{new Date(note.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
        <h2 class="text-foreground text-[0.95rem] font-medium group-hover:underline underline-offset-[3px] decoration-border mt-0.5">
          {note.data.title}
        </h2>
        <p class="text-muted text-[0.8rem] mt-0.5">{note.data.description}</p>
      </a>
    ))}
  </div>

  <!-- Email signup -->
  <div class="border border-border rounded-lg p-6 mb-12">
    <h3 class="text-foreground text-sm font-medium mb-1">Get notified when I write</h3>
    <p class="text-muted text-xs mb-4">No spam. Unsubscribe anytime.</p>
    <form action="https://buttondown.com/api/emails/embed-subscribe/tyeetale" method="post" target="popupwindow" class="flex gap-2">
      <input
        type="email"
        name="email"
        placeholder="you@email.com"
        required
        class="flex-1 px-3 py-1.5 text-sm bg-surface border border-border rounded-md text-foreground placeholder-muted focus:outline-none focus:border-muted-foreground transition-colors"
      />
      <button type="submit" class="px-3 py-1.5 text-sm bg-foreground text-background rounded-md hover:opacity-90 transition-opacity">
        subscribe
      </button>
    </form>
  </div>

  <Footer />
</BaseLayout>
