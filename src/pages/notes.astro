---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Notes" description="Thoughts on building, AI, and systems thinking by Thomas Yee." path="/notes" noindex={true}>
  <Header />
  <div class="flex-1 flex flex-col justify-center items-center text-center py-20">
    <h1 class="font-heading font-bold text-xl text-foreground mb-3">Notes</h1>
    <p class="text-muted-foreground text-sm max-w-[300px]">
      Thoughts on building, AI, and systems thinking. Writing in progress.
    </p>
    <span class="text-muted text-xs mt-6 border border-border px-3 py-1 rounded-full">
      coming soon
    </span>
  </div>
  <Footer />
</BaseLayout>
