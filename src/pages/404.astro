---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Not Found" description="Page not found." path="/404" noindex={true}>
  <Header />
  <div class="flex-1 flex flex-col justify-center items-center text-center py-20">
    <h1 class="font-heading font-bold text-4xl text-foreground mb-3">404</h1>
    <p class="text-muted-foreground text-sm max-w-[300px] mb-6">
      This page doesn't exist. Maybe it used to, or maybe you're exploring.
    </p>
    <a href="/" class="text-sm text-muted border border-border px-4 py-2 rounded hover:text-foreground transition-colors">
      go home
    </a>
  </div>
  <Footer />
</BaseLayout>
