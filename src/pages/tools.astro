---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ToolsGrid from '../components/tools/ToolsGrid';
---

<BaseLayout title="Tools" description="Interactive tools and widgets by Thomas Yee." path="/tools">
  <Header />
  <h1 class="font-heading font-bold text-xl text-foreground mb-2">Tools</h1>
  <p class="text-muted-foreground text-sm mb-8">
    Interactive things. Play around.
  </p>
  <ToolsGrid client:visible />
  <Footer />
</BaseLayout>
