---
<html>
  <head>
    <style>
      body {
        margin: 0;
        width: 1200px;
        height: 630px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #0a0a0a;
        font-family: system-ui, sans-serif;
      }
      .container {
        text-align: center;
      }
      .name {
        font-size: 64px;
        font-weight: 700;
        color: #e5e5e5;
        margin-bottom: 16px;
        letter-spacing: -0.02em;
      }
      .tagline {
        font-size: 24px;
        color: #a3a3a3;
        max-width: 600px;
        line-height: 1.4;
      }
      .dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: #4ade80;
        display: inline-block;
        margin-right: 8px;
        box-shadow: 0 0 8px rgba(74, 222, 128, 0.5);
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="name">tyeetale</div>
      <div class="tagline">
        <span class="dot"></span>
        Operator and builder. AI systems, data infrastructure, and products.
      </div>
    </div>
  </body>
</html>
