---
import Wordmark from './Wordmark';

const navLinks = [
  { label: 'about', href: '/about' },
  { label: 'projects', href: '/projects' },
  { label: 'notes', href: '/notes' },
  { label: 'tools', href: '/tools' },
];
---

<header class="flex items-center justify-between pb-4 mb-10 border-b border-border">
  <Wordmark client:load />
  <nav class="flex items-center gap-3">
    {navLinks.map((link, idx) => (
      <>
        <a href={link.href} class="text-xs text-muted hover:text-foreground transition-colors">
          {link.label}
        </a>
        {idx < navLinks.length - 1 && <span class="text-border text-xs">&middot;</span>}
      </>
    ))}
  </nav>
</header>
