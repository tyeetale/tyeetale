---
import ThemeToggle from './theme/ThemeToggle';
import { socialLinks } from '../data/links';
---

<footer class="border-t border-border pt-5 mt-12 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
  <div class="flex items-center gap-4">
    {socialLinks.map((link) => (
      <a
        href={link.href}
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted hover:text-foreground transition-colors"
        aria-label={link.label}
      >
        {link.icon === 'XIcon' && (
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
        )}
        {link.icon === 'Mail' && (
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        )}
        {link.icon === 'Github' && (
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        )}
        {link.icon === 'Linkedin' && (
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
        )}
      </a>
    ))}
  </div>
  <div class="flex items-center gap-3">
    <ThemeToggle client:load />
    <div class="flex gap-0.5 bg-surface rounded-md p-0.5 text-xs">
      <a href="/" class="px-2 py-0.5 rounded transition-colors bg-border text-foreground">human</a>
      <a href="/llms.txt" target="_blank" rel="noopener noreferrer" class="px-2 py-0.5 rounded transition-colors text-muted hover:text-muted-foreground">machine</a>
    </div>
    <a href="/graph" class="text-xs text-muted border border-border px-2 py-0.5 rounded hover:text-foreground transition-colors">graph</a>
    <a href="/qr" class="text-xs text-muted border border-border px-2 py-0.5 rounded hover:text-foreground transition-colors">QR</a>
  </div>
</footer>
